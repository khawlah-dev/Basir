# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=0
# Use ${{RAILWAY_PUBLIC_DOMAIN}} in Railway settings for these:
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database
# Railway will provide DATABASE_URL automatically when you add a PostgreSQL service.
DATABASE_URL=

# Force logging to console (required for Railway logs)
PYTHONUNBUFFERED=1 
